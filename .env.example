# Root .env.example — copy to .env and fill in.
# Single source for frontend, backend, worker, and docker-compose in local development.

# ---- Core app settings ----
APP_NAME=NovelTTS Backend
ENVIRONMENT=development

# ---- Local Postgres ----
POSTGRES_USER=noveltts
POSTGRES_PASSWORD=noveltts_dev
POSTGRES_DB=noveltts
# Shared DB URL for Prisma + backend (backend converts this to asyncpg internally)
DATABASE_URL=postgresql://noveltts:noveltts_dev@localhost:6543/noveltts

# ---- Local Redis ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend-compatible aliases (optional but recommended)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8010

# ---- AI and storage providers ----
GEMINI_API_KEY=your-gemini-api-key
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=noveltts-audio
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# ---- TTS defaults ----
KOKORO_DEVICE=cpu
EDGE_TTS_DEFAULT_VOICE=en-US-AriaNeural
