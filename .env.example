# Root .env.example — copy to .env and fill in.
# App-specific envs live in frontend/.env.example, backend/.env.example, worker/.env.example
# This file holds only values needed by docker-compose at the project root.

# ---- Local Postgres (docker-compose) ----
POSTGRES_USER=noveltts
POSTGRES_PASSWORD=noveltts_dev
POSTGRES_DB=noveltts

# ---- Local Redis (docker-compose) ----
REDIS_PORT=6379
