generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SegmentType {
  narration
  dialogue
  thought
}

enum JobStatus {
  queued
  processing
  completed
  failed
}

model User {
  id        String   @id @db.Uuid
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  books     Book[]

  @@map("users")
}

model Book {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @db.Uuid
  title          String
  author         String?
  originLanguage String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters       Chapter[]
  characters     Character[]
  pronunciations PronunciationEntry[]

  @@index([userId])
  @@map("books")
}

model Chapter {
  id          String      @id @default(uuid()) @db.Uuid
  bookId      String      @db.Uuid
  chapterIdx  Int
  title       String?
  rawText     String
  status      String      @default("uploaded")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  segments    Segment[]
  audioJobs   AudioJob[]

  @@index([bookId, chapterIdx])
  @@unique([bookId, chapterIdx])
  @@map("chapters")
}

model Segment {
  id          String      @id @default(uuid()) @db.Uuid
  chapterId   String      @db.Uuid
  segmentIdx  Int
  text        String
  type        SegmentType @default(narration)
  characterId String?     @db.Uuid
  confidence  Float?
  audioUrl    String?
  contentHash String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  chapter     Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  character   Character?  @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([chapterId, segmentIdx])
  @@unique([chapterId, segmentIdx])
  @@map("segments")
}

model Character {
  id               String            @id @default(uuid()) @db.Uuid
  bookId           String            @db.Uuid
  name             String
  role             String?
  voiceId          String?           @db.Uuid
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  book             Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  segments         Segment[]
  profile          CharacterProfile?
  voiceRequirement VoiceRequirement?

  @@index([bookId, name])
  @@map("characters")
}

model CharacterProfile {
  id           String    @id @default(uuid()) @db.Uuid
  characterId  String    @unique @db.Uuid
  age          String?
  gender       String?
  personality  Json
  speechStyle  Json
  role         String?
  voiceNotes   String?
  confidence   Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@map("character_profiles")
}

model VoiceRequirement {
  id          String    @id @default(uuid()) @db.Uuid
  characterId String    @unique @db.Uuid
  pitch       String?
  ageGroup    String?
  tone        String?
  pacing      String?
  energy      String?
  avoid       Json
  rationale   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@map("voice_requirements")
}

model Voice {
  id         String    @id @default(uuid()) @db.Uuid
  provider   String
  providerId String
  name       String
  gender     String?
  locale     String?
  pitch      String?
  ageGroup   String?
  tone       String?
  energy     String?
  sampleUrl  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([provider, providerId])
  @@map("voices")
}

model AudioJob {
  id         String    @id @default(uuid()) @db.Uuid
  chapterId  String    @db.Uuid
  status     JobStatus @default(queued)
  provider   String?
  progress   Int       @default(0)
  error      String?
  outputUrl  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  chapter    Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId, status])
  @@map("audio_jobs")
}

model PronunciationEntry {
  id          String   @id @default(uuid()) @db.Uuid
  bookId       String   @db.Uuid
  term         String
  phoneme      String
  languageCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, term])
  @@map("pronunciation_entries")
}
